    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.8",
    "@tailwindcss/vite": "^4.1.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
